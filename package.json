{
  "name": "@netly/ui",
  "version": "1.0.0",
  "description": "Netly cross-platform UI component library for Expo (NativeWind) and Web (Tailwind CSS)",
  "author": "Netly Inc.",
  "license": "MIT",
  "keywords": ["netly", "design-system", "react-native", "expo", "nativewind", "tailwind", "fintech"],
  "repository": {
    "type": "git",
    "url": "https://github.com/netly/ui"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.mjs",
      "require": "./dist/tokens/index.js"
    },
    "./tailwind": "./tailwind.config.js",
    "./global.css": "./global.css"
  },
  "files": [
    "dist",
    "global.css",
    "tailwind.config.js",
    "tailwind.js",
    "tokens.js",
    "README.md"
  ],
  "sideEffects": ["./global.css"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "nativewind": ">=4.0.0",
    "tailwindcss": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "react-native": { "optional": true },
    "nativewind": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
